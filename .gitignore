.idea/
# .gitignore — keep secrets, caches, and artifacts out of version control
day-*/data/raw/*        # raw data — too large for Git
day-*/.venv/  # virtual environments in day-* directories
day-*/.venv
day-*/__pycache__/  # cache in day-* directories
day-*/.pytest_cache/  # pytest cache in day-* directories
day-*/.ipynb_checkpoints/  # Jupyter checkpoints in day-* directories
day-*/models/*.pkl  # model artifacts in day-* directories
day-*/dist/  # build outputs in day-* directories
day-*/.egg-info/  # package metaday in day-* directories
day-*/.env  # environment files in day-* directories
day-*/.pyc  # compiled Python bytecode in day-* directories
Makefile
